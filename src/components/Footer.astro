---

<footer class="site-footer">
	<div class="footer-inner">
		<nav class="social-links" aria-label="Social links">
			{SOCIAL_LINKS.map((link) => (
				<a
					href={link.href}
					aria-label={link.name}
					target={link.href.startsWith("mailto:") || link.href.startsWith("/") ? undefined : "_blank"}
					rel={("rel" in link ? link.rel + " " : "") + (link.href.startsWith("http") ? "noopener noreferrer" : "")}
				>
					<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
						<path d={icons[link.icon]} />
					</svg>
				</a>
			))}
		</nav>

		<p class="copyright">
			&copy; {year} {SITE.subtitle}, made in
			<a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>,
			emojis provided by
			<a href="https://mutant.tech" target="_blank" rel="noopener noreferrer">Mutant Standard</a>
			(<a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" target="_blank" rel="noopener noreferrer">CC BY-NC-SA 4.0</a>)
		</p>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid var(--color-border);
		margin-top: var(--space-4xl);
		padding: var(--space-2xl) var(--space-lg);
	}

	.footer-inner {
		max-width: calc(
			var(--sidebar-width) + var(--content-width) + var(--margin-width) +
				var(--layout-gap) * 2
		);
		margin-inline: auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-lg);
	}

	.social-links {
		display: flex;
		gap: var(--space-lg);
	}

	.social-links a {
		color: var(--color-text-faint);
		transition: color var(--transition-fast);
	}

	.social-links a:hover {
		color: var(--color-text);
	}

	.copyright {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--color-text-faint);
		text-align: center;
		line-height: 1.8;
	}

	.copyright a {
		color: var(--color-text-muted);
		border-bottom: 1px dotted currentColor;
		transition: color var(--transition-fast);
	}

	.copyright a:hover {
		color: var(--color-accent);
	}

	@media (min-width: 80rem) {
		.site-footer {
			padding-inline: var(--space-xl);
		}
	}
</style>
