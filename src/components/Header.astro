---
import { NAV_LINKS, SHOW_ACCENT_SLIDER, SITE } from "../consts";
---

<header class="site-header">
	<div class="header-inner">
		<a href="/" class="site-logo" aria-label="Home">
			<span class="logo-prompt">~/</span>{SITE.subtitle}<span class="logo-prompt">&nbsp;$</span>
		</a>

		<nav class="site-nav" aria-label="Main navigation">
			<button
				class="nav-toggle"
				aria-expanded="false"
				aria-controls="nav-links"
				aria-label="Toggle navigation"
			>
				<svg class="icon-menu" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
					<line x1="3" y1="5" x2="17" y2="5" />
					<line x1="3" y1="10" x2="17" y2="10" />
					<line x1="3" y1="15" x2="17" y2="15" />
				</svg>
				<svg class="icon-close" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
					<line x1="4" y1="4" x2="16" y2="16" />
					<line x1="16" y1="4" x2="4" y2="16" />
				</svg>
			</button>

			<ul id="nav-links" class="nav-links">
				{NAV_LINKS.map((link) => (
					<li>
						<a
							href={link.href}
							class:list={["nav-link", { active: Astro.url.pathname === link.href, external: link.external }]}
							target={link.external ? "_blank" : undefined}
							rel={link.external ? "noopener noreferrer" : undefined}
						>
							{link.text}
							{link.external && <span class="nav-ext-glyph" aria-hidden="true">↗</span>}
						</a>
					</li>
				))}
			</ul>
		</nav>

		<div class="header-actions">
		{SHOW_ACCENT_SLIDER && (
			<div class="accent-picker">
				<div class="accent-slider" aria-hidden="true">
					<input
						type="range"
						min="0"
						max="360"
						step="1"
						value="0"
						aria-label="Accent hue"
						tabindex="-1"
					/>
				</div>
				<button
					class="accent-toggle"
					type="button"
					aria-expanded="false"
					aria-controls="accent-slider"
					aria-label="Toggle accent hue slider"
					title="Accent hue"
				>
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="12" cy="12" r="9" />
						<circle cx="12" cy="6.5" r="1.2" fill="currentColor" stroke="none" />
						<circle cx="17" cy="9.5" r="1.2" fill="currentColor" stroke="none" />
						<circle cx="17" cy="15" r="1.2" fill="currentColor" stroke="none" />
						<circle cx="7" cy="9.5" r="1.2" fill="currentColor" stroke="none" />
						<path d="M12 21c-1.5 0-2.5-1-2.5-2.2 0-1 .7-1.6.7-2.5 0-.9-.8-1.3-1.7-1.3" />
					</svg>
				</button>
			</div>
		)}

		<button
			class="theme-toggle"
			aria-label="Toggle theme"
		>
			<svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
				<circle cx="12" cy="12" r="5" />
				<line x1="12" y1="1" x2="12" y2="3" />
				<line x1="12" y1="21" x2="12" y2="23" />
				<line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
				<line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
				<line x1="1" y1="12" x2="3" y2="12" />
				<line x1="21" y1="12" x2="23" y2="12" />
				<line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
				<line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
			</svg>
			<svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
				<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
			</svg>
		</button>
		</div>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 100;
		background-color: var(--color-header-bg);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--color-border);
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: calc(
			var(--sidebar-width) + var(--content-width) + var(--margin-width) +
				var(--layout-gap) * 2
		);
		margin-inline: auto;
		padding: var(--space-md) var(--space-lg);
	}

	/* Logo */
	.site-logo {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		font-weight: 500;
		letter-spacing: -0.02em;
		white-space: nowrap;
	}

	.site-logo:hover {
		color: var(--color-accent);
	}

	.logo-prompt {
		color: var(--color-text-faint);
	}

	/* Nav */
	.site-nav {
		display: flex;
		align-items: center;
	}

	.nav-links {
		display: flex;
		gap: var(--space-xl);
	}

	.nav-link {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		text-transform: lowercase;
		letter-spacing: 0.04em;
		padding-bottom: 2px;
		border-bottom: 1px solid transparent;
	}

	.nav-link.external {
		color: var(--color-text-muted);
	}

	.nav-ext-glyph {
		display: inline-block;
		margin-left: 0.2em;
		font-size: 0.85em;
		color: var(--color-text-faint);
		transition: transform var(--transition-fast);
	}

	.nav-link.external:hover .nav-ext-glyph {
		transform: translate(1px, -1px);
		color: var(--color-accent);
	}

	.nav-link:hover,
	.nav-link.active {
		border-bottom-color: var(--color-text);
	}

	.nav-link.active {
		color: var(--color-text);
	}

	/* Hamburger */
	.nav-toggle {
		display: none;
		background: none;
		border: none;
		cursor: pointer;
		padding: var(--space-xs);
		color: var(--color-text);
	}

	.nav-toggle .icon-close {
		display: none;
	}

	.nav-toggle[aria-expanded="true"] .icon-menu {
		display: none;
	}

	.nav-toggle[aria-expanded="true"] .icon-close {
		display: block;
	}

	.header-actions {
		display: flex;
		align-items: center;
	}

	/* Accent hue picker (toggle button + collapsible slider) */
	.accent-picker {
		position: relative;
		display: flex;
		align-items: center;
	}

	.accent-toggle {
		background: none;
		border: none;
		cursor: pointer;
		padding: var(--space-xs);
		color: var(--color-text-muted);
		transition: color var(--transition-fast);
		display: flex;
		align-items: center;
	}

	.accent-toggle:hover,
	.accent-toggle[aria-expanded="true"] {
		color: var(--color-accent);
	}

	.accent-slider {
		position: absolute;
		top: calc(100% + var(--space-sm));
		right: 0;
		display: flex;
		align-items: center;
		padding: var(--space-sm) var(--space-md);
		background-color: var(--color-header-bg);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		opacity: 0;
		transform: translateY(-4px);
		pointer-events: none;
		transition:
			opacity var(--transition-base),
			transform var(--transition-base);
	}

	.accent-picker:has(.accent-toggle[aria-expanded="true"]) .accent-slider {
		opacity: 1;
		transform: translateY(0);
		pointer-events: auto;
	}

	.accent-slider input[type="range"] {
		-webkit-appearance: none;
		appearance: none;
		width: 10rem;
		height: 6px;
		background: linear-gradient(
			to right,
			hsl(0 60% 50%),
			hsl(60 60% 50%),
			hsl(120 60% 50%),
			hsl(180 60% 50%),
			hsl(240 60% 50%),
			hsl(300 60% 50%),
			hsl(360 60% 50%)
		);
		border-radius: 999px;
		outline: none;
		cursor: pointer;
		opacity: 0.7;
		transition: opacity var(--transition-fast);
	}

	.accent-slider input[type="range"]:hover {
		opacity: 1;
	}

	.accent-slider input[type="range"]::-webkit-slider-thumb {
		-webkit-appearance: none;
		appearance: none;
		width: 18px;
		height: 18px;
		border-radius: 50%;
		background: var(--color-accent);
		border: 2px solid var(--color-bg);
		box-shadow: 0 0 0 1px var(--color-border-strong);
		cursor: pointer;
	}

	.accent-slider input[type="range"]::-moz-range-thumb {
		width: 18px;
		height: 18px;
		border-radius: 50%;
		background: var(--color-accent);
		border: 2px solid var(--color-bg);
		box-shadow: 0 0 0 1px var(--color-border-strong);
		cursor: pointer;
	}

	@media (max-width: 44rem) {
		.accent-picker {
			display: none;
		}
	}

	/* Theme toggle */
	.theme-toggle {
		background: none;
		border: none;
		cursor: pointer;
		padding: var(--space-xs);
		color: var(--color-text-muted);
		transition: color var(--transition-fast);
	}

	.theme-toggle:hover {
		color: var(--color-text);
	}

	/* Show sun in dark mode, moon in light mode */
	.icon-sun {
		display: none;
	}

	:global([data-theme="dark"]) .icon-sun {
		display: block;
	}

	:global([data-theme="dark"]) .icon-moon {
		display: none;
	}

	/* Mobile */
	@media (max-width: 44rem) {
		.nav-toggle {
			display: block;
		}

		.nav-links {
			display: none;
			position: absolute;
			top: 100%;
			left: 0;
			right: 0;
			flex-direction: column;
			gap: 0;
			background-color: var(--color-header-bg);
			backdrop-filter: blur(12px);
			-webkit-backdrop-filter: blur(12px);
			border-bottom: 1px solid var(--color-border);
			padding: var(--space-md) var(--space-lg);
		}

		.nav-links.open {
			display: flex;
		}

		.nav-link {
			display: block;
			padding: var(--space-sm) 0;
			border-bottom: none;
		}

		.nav-link:hover,
		.nav-link.active {
			color: var(--color-accent);
			border-bottom: none;
		}
	}

	@media (min-width: 80rem) {
		.header-inner {
			padding-inline: var(--space-xl);
		}
	}
</style>

<script>
	function setupHeader() {
		const toggle = document.querySelector(".nav-toggle");
		const navLinks = document.getElementById("nav-links");

		if (toggle && navLinks) {
			toggle.addEventListener("click", () => {
				const expanded = toggle.getAttribute("aria-expanded") === "true";
				toggle.setAttribute("aria-expanded", String(!expanded));
				navLinks.classList.toggle("open");
			});
		}

		const accentSlider = document.querySelector<HTMLInputElement>(
			".accent-slider input[type='range']",
		);
		const accentToggle = document.querySelector<HTMLButtonElement>(
			".accent-toggle",
		);
		if (accentSlider) {
			const storedHue = localStorage.getItem("accent-hue");
			if (storedHue !== null) {
				accentSlider.value = storedHue;
			}
			accentSlider.addEventListener("input", () => {
				const hue = accentSlider.value;
				document.documentElement.style.setProperty("--accent-hue", hue);
				localStorage.setItem("accent-hue", hue);
			});
		}
		if (accentToggle && accentSlider) {
			accentToggle.addEventListener("click", () => {
				const expanded =
					accentToggle.getAttribute("aria-expanded") === "true";
				accentToggle.setAttribute("aria-expanded", String(!expanded));
				accentSlider.tabIndex = expanded ? -1 : 0;
				if (!expanded) {
					// focus the slider when opening for keyboard users
					setTimeout(() => accentSlider.focus(), 200);
				}
			});
		}

		const themeToggle = document.querySelector(".theme-toggle");
		if (themeToggle) {
			themeToggle.addEventListener("click", () => {
				const current =
					document.documentElement.getAttribute("data-theme");
				const next = current === "dark" ? "light" : "dark";
				document.documentElement.setAttribute("data-theme", next);
				localStorage.setItem("theme", next);
			});
		}
	}

	setupHeader();
	document.addEventListener("astro:after-swap", setupHeader);
</script>
