---
import { Image } from "astro:assets";
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const page = await getEntry("pages", "about");

if (!page) {
  throw new Error("About page content not found");
}

const { Content } = await render(page);

function parseColumns(columns?: string) {
  if (!columns) return { single: true, style: "" };
  const parts = columns.split("-");
  if (parts.length === 1) {
    return { single: true, style: `--page-width: ${parts[0]};` };
  }
  return {
    single: false,
    style: `--col-left: ${parts[0]}; --col-right: ${parts[1]};`,
  };
}

const col = parseColumns(page.data.columns);
---

<BaseLayout title={page.data.title} description={page.data.description}>
	<article
		class="about-page"
		data-columns={col.single ? undefined : "dual"}
		style={col.style || undefined}
	>
		{
			page.data.cover && (
				<figure class="page-cover" data-lightbox-target>
					<Image
						src={page.data.cover}
						alt={`Cover image for ${page.data.title}`}
						widths={[600, 900, 1200]}
						sizes="(max-width: 71.99rem) 100vw, 50vw"
					/>
				</figure>
			)
		}

		<div class="about-content page-column prose" data-numbered-headings={page.data.numberedHeadings || undefined}>
			<Content />
		</div>
	</article>
</BaseLayout>

<style>
	.about-page {
		padding-top: var(--space-3xl);
		padding-bottom: var(--space-4xl);
		padding-inline: var(--space-lg);
	}

	.page-cover {
		margin-bottom: var(--space-xl);
	}

	.page-cover :global(img) {
		width: 100%;
		max-height: 20rem;
		object-fit: cover;
		border-radius: var(--radius-md);
		cursor: zoom-in;
	}

	/* First h1 gets special treatment */
	.about-content :global(h1:first-child) {
		font-size: var(--text-4xl);
		margin-bottom: var(--space-2xl);
	}

	/* Subsequent h1s act as major section dividers */
	.about-content :global(h1) {
		font-size: var(--text-3xl);
		margin-top: var(--space-4xl);
		margin-bottom: var(--space-lg);
		padding-bottom: var(--space-sm);
		border-bottom: 2px solid var(--color-border);
	}

	@media (min-width: 80rem) {
		.about-page {
			padding-inline: var(--space-xl);
		}
	}
</style>
