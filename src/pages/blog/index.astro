---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const allPosts = await getCollection("posts", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const posts = allPosts.sort(
  (a, b) => b.data.published.getTime() - a.data.published.getTime(),
);

type Post = (typeof posts)[number];

const readingStats = new Map<string, { words: number; minutes: number }>();
await Promise.all(
  posts.map(async (post) => {
    const { remarkPluginFrontmatter } = await render(post);
    const { words, minutes } = remarkPluginFrontmatter as {
      words?: number;
      minutes?: number;
    };
    if (typeof words === "number" && typeof minutes === "number") {
      readingStats.set(post.id, { words, minutes });
    }
  }),
);

const byYear = new Map<number, Post[]>();
for (const post of posts) {
  const y = post.data.published.getFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(post);
}
const years = [...byYear.keys()].sort((a, b) => b - a);

const categoryCounts = new Map<string, number>();
const tagCounts = new Map<string, number>();
for (const post of posts) {
  if (post.data.category) {
    categoryCounts.set(
      post.data.category,
      (categoryCounts.get(post.data.category) ?? 0) + 1,
    );
  }
  for (const tag of post.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}
const categories = [...categoryCounts.keys()].sort((a, b) =>
  a.localeCompare(b),
);
const tags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .map(([t]) => t);

// Initial filter state from URL (SSR first paint)
const params = Astro.url.searchParams;
const fYear = params.get("year") ?? "";
const fCategory = params.get("category") ?? "";
const fTag = params.get("tag") ?? "";
const hasFilter = Boolean(fYear || fCategory || fTag);

function matches(post: Post): boolean {
  if (fYear && String(post.data.published.getFullYear()) !== fYear)
    return false;
  if (fCategory && post.data.category !== fCategory) return false;
  if (fTag && !post.data.tags.includes(fTag)) return false;
  return true;
}

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}

function formatDateShort(date: Date): string {
  return date.toLocaleDateString("en-US", { month: "short", day: "2-digit" });
}

function hrefFor(key: string, value: string): string {
  const p = new URLSearchParams(params);
  if (p.get(key) === value) p.delete(key);
  else p.set(key, value);
  const qs = p.toString();
  return qs ? `/blog/?${qs}` : "/blog/";
}

const filterBits: { label: string; value: string; key: string }[] = [];
if (fCategory)
  filterBits.push({ label: "in", value: fCategory, key: "category" });
if (fTag) filterBits.push({ label: "tagged", value: fTag, key: "tag" });
if (fYear) filterBits.push({ label: "from", value: fYear, key: "year" });
---

<BaseLayout title="Blog" description="All posts">
	<section
		class="blog-page"
		data-columns="dual"
		style="--col-left: 50vw; --col-right: 22vw;"
	>
		<div class="blog-main">
			<header class="blog-header">
				<h1>Blog</h1>
				<p class="filter-sentence" hidden={!hasFilter}>
					<span class="filter-text">
						Showing posts{" "}
						{filterBits.map((b, i) => (
							<>
								{i > 0 && " "}
								{b.label}{" "}
								<em>{b.value}</em>
								{i < filterBits.length - 1 ? "" : "."}
							</>
						))}
					</span>
					<a href="/blog/" class="clear-filters">clear</a>
				</p>
			</header>

			<ol class="year-groups" data-density="reading">
				{
					years.map((year) => {
						const yearPosts = byYear.get(year)!;
						const anyVisible = yearPosts.some(matches);
						return (
							<li
								class="year-group"
								data-year={year}
								hidden={hasFilter && !anyVisible}
							>
								<h2 class="year-heading">{year}</h2>
								<ul class="post-list">
									{yearPosts.map((post) => (
										<li
											class:list={[
												"post-item",
												{ draft: post.data.draft },
											]}
											data-year={post.data.published.getFullYear()}
											data-category={post.data.category ?? ""}
											data-tags={post.data.tags.join(" ")}
											hidden={hasFilter && !matches(post)}
										>
											<a class="post-link" href={`/blog/${post.id}/`}>
												<span class="post-date">
													<time
														datetime={post.data.published.toISOString()}
													>
														<span class="date-full">
															{formatDate(post.data.published)}
														</span>
														<span class="date-short">
															{formatDateShort(post.data.published)}
														</span>
													</time>
												</span>
												<span class="post-body">
													<span class="post-title">
														{post.data.draft && (
															<span class="draft-badge">draft</span>
														)}
														{post.data.title}
													</span>
													{post.data.description && (
														<span class="post-description">
															{post.data.description}
														</span>
													)}
												</span>
												<span class="post-facets">
													{readingStats.has(post.id) && (
														<span class="post-reading">
															{readingStats
																.get(post.id)!
																.words.toLocaleString()}{" "}
															words ·{" "}
															{readingStats.get(post.id)!.minutes} min read
														</span>
													)}
													{(post.data.category ||
														post.data.tags.length > 0) && (
														<span class="post-taxonomy">
															{post.data.category && (
																<span class="post-category">
																	{post.data.category}
																</span>
															)}
															{post.data.tags.length > 0 && (
																<span class="post-tags">
																	{post.data.tags.map((tag) => (
																		<span class="post-tag">{tag}</span>
																	))}
																</span>
															)}
														</span>
													)}
												</span>
											</a>
										</li>
									))}
								</ul>
							</li>
						);
					})
				}
			</ol>

			<p class="no-results" hidden={!hasFilter || posts.some(matches)}>
				No posts match the current filters.
			</p>
		</div>

		<aside class="filter-rail">
			<nav class="rail-section">
				<h3 class="rail-label">Years</h3>
				<ul class="rail-list rail-years">
					{
						years.map((y) => (
							<li>
								<a
									href={hrefFor("year", String(y))}
									data-filter="year"
									data-value={String(y)}
									class:list={{ active: fYear === String(y) }}
								>
									{y}
								</a>
							</li>
						))
					}
				</ul>
			</nav>

			{
				categories.length > 0 && (
					<nav class="rail-section">
						<h3 class="rail-label">Categories</h3>
						<ul class="rail-list rail-categories">
							{categories.map((c) => (
								<li>
									<a
										href={hrefFor("category", c)}
										data-filter="category"
										data-value={c}
										class:list={{ active: fCategory === c }}
									>
										{c}
									</a>
								</li>
							))}
						</ul>
					</nav>
				)
			}

			{
				tags.length > 0 && (
					<nav class="rail-section">
						<h3 class="rail-label">Tags</h3>
						<ul class="rail-list rail-tags">
							{tags.map((t) => (
								<li>
									<a
										href={hrefFor("tag", t)}
										data-filter="tag"
										data-value={t}
										class:list={{ active: fTag === t }}
									>
										{t}
									</a>
								</li>
							))}
						</ul>
					</nav>
				)
			}

			<div class="rail-section density">
				<h3 class="rail-label">View</h3>
				<div class="density-toggle">
					<button type="button" data-density-btn="reading">reading</button>
					<span aria-hidden="true">/</span>
					<button type="button" data-density-btn="index">index</button>
				</div>
			</div>
		</aside>
	</section>
</BaseLayout>

<script>
	function escapeHtml(s: string): string {
		return s.replace(
			/[&<>"']/g,
			(c) =>
				({
					"&": "&amp;",
					"<": "&lt;",
					">": "&gt;",
					'"': "&quot;",
					"'": "&#39;",
				})[c] as string,
		);
	}

	function applyFilters() {
		const params = new URLSearchParams(location.search);
		const fYear = params.get("year") ?? "";
		const fCat = params.get("category") ?? "";
		const fTag = params.get("tag") ?? "";
		const hasFilter = Boolean(fYear || fCat || fTag);

		document.querySelectorAll<HTMLElement>(".post-item").forEach((item) => {
			const year = item.dataset.year ?? "";
			const cat = item.dataset.category ?? "";
			const tags = (item.dataset.tags ?? "").split(" ").filter(Boolean);
			const match =
				(!fYear || year === fYear) &&
				(!fCat || cat === fCat) &&
				(!fTag || tags.includes(fTag));
			item.hidden = !match;
		});

		document.querySelectorAll<HTMLElement>(".year-group").forEach((grp) => {
			const hasVisible = grp.querySelector(".post-item:not([hidden])");
			grp.hidden = !hasVisible;
		});

		document
			.querySelectorAll<HTMLElement>("[data-filter]")
			.forEach((link) => {
				const key = link.dataset.filter!;
				const value = link.dataset.value!;
				const current = params.get(key) ?? "";
				link.classList.toggle("active", current === value);
			});

		const sentence = document.querySelector<HTMLElement>(".filter-sentence");
		if (sentence) {
			if (!hasFilter) {
				sentence.hidden = true;
			} else {
				sentence.hidden = false;
				const bits: string[] = [];
				if (fCat) bits.push(`in <em>${escapeHtml(fCat)}</em>`);
				if (fTag) bits.push(`tagged <em>${escapeHtml(fTag)}</em>`);
				if (fYear) bits.push(`from <em>${escapeHtml(fYear)}</em>`);
				const text = sentence.querySelector(".filter-text");
				if (text)
					text.innerHTML = `Showing posts ${bits.join(" ")}.`;
			}
		}

		const noResults = document.querySelector<HTMLElement>(".no-results");
		if (noResults) {
			const anyVisible = document.querySelector(".post-item:not([hidden])");
			noResults.hidden = !hasFilter || Boolean(anyVisible);
		}
	}

	function onFilterClick(e: Event) {
		const link = e.currentTarget as HTMLAnchorElement;
		e.preventDefault();
		const params = new URLSearchParams(location.search);
		const key = link.dataset.filter!;
		const value = link.dataset.value!;
		if (params.get(key) === value) params.delete(key);
		else params.set(key, value);
		const qs = params.toString();
		history.pushState({}, "", qs ? `?${qs}` : location.pathname);
		applyFilters();
	}

	document
		.querySelectorAll<HTMLAnchorElement>("[data-filter]")
		.forEach((l) => l.addEventListener("click", onFilterClick));

	const clearBtn = document.querySelector<HTMLAnchorElement>(".clear-filters");
	clearBtn?.addEventListener("click", (e) => {
		e.preventDefault();
		history.pushState({}, "", location.pathname);
		applyFilters();
	});

	window.addEventListener("popstate", applyFilters);

	// Density toggle
	const yearGroups = document.querySelector<HTMLElement>(".year-groups");
	const densityBtns = document.querySelectorAll<HTMLButtonElement>(
		"[data-density-btn]",
	);
	const savedDensity =
		(localStorage.getItem("blog-density") as "reading" | "index" | null) ??
		"reading";
	if (yearGroups) yearGroups.dataset.density = savedDensity;
	densityBtns.forEach((btn) => {
		btn.classList.toggle(
			"active",
			btn.dataset.densityBtn === savedDensity,
		);
		btn.addEventListener("click", () => {
			const d = btn.dataset.densityBtn as "reading" | "index";
			if (yearGroups) yearGroups.dataset.density = d;
			localStorage.setItem("blog-density", d);
			densityBtns.forEach((b) =>
				b.classList.toggle("active", b.dataset.densityBtn === d),
			);
		});
	});

	// Re-run once in case SSR state differs from URL (shouldn't, but cheap)
	applyFilters();
</script>

<style>
	.blog-page {
		padding-top: var(--space-3xl);
		padding-bottom: var(--space-4xl);
		padding-inline: var(--space-lg);
		max-width: 100%;
	}

	.blog-main {
		max-width: var(--content-width);
		margin-inline: auto;
	}

	@media (min-width: 72rem) {
		.blog-page[data-columns="dual"] {
			display: grid;
			grid-template-columns: var(--col-left) var(--col-right);
			gap: var(--layout-gap);
			justify-content: center;
			align-items: start;
		}

		.blog-main {
			max-width: none;
			margin-inline: 0;
			min-width: 0;
		}
	}

	/* --- Header & filter sentence --- */

	.blog-header {
		margin-bottom: var(--space-2xl);
	}

	.blog-header h1 {
		font-size: var(--text-4xl);
		font-weight: 800;
		letter-spacing: -0.02em;
	}

	.filter-sentence {
		margin-top: var(--space-md);
		font-family: var(--font-body);
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		font-style: italic;
		display: flex;
		align-items: baseline;
		gap: var(--space-md);
		flex-wrap: wrap;
	}

	.filter-sentence em {
		color: var(--color-text);
		font-style: italic;
		font-weight: 500;
	}

	.clear-filters {
		font-family: var(--font-mono);
		font-style: normal;
		font-size: var(--text-xs);
		color: var(--color-text-faint);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		border-bottom: 1px dotted currentColor;
		transition: color var(--transition-base);
	}

	.clear-filters:hover {
		color: var(--color-accent);
	}

	/* --- Year groups --- */

	.year-group {
		margin-bottom: var(--space-3xl);
	}

	.year-group:last-child {
		margin-bottom: 0;
	}

	.year-heading {
		font-family: var(--font-heading);
		font-size: var(--text-3xl);
		font-weight: 400;
		color: var(--color-text-muted);
		letter-spacing: -0.01em;
		margin-bottom: var(--space-lg);
		border-bottom: 1px solid var(--color-border);
		padding-bottom: var(--space-xs);
	}

	.post-list {
		display: flex;
		flex-direction: column;
	}

	/* --- Post entry (reading view) --- */

	.post-link {
		display: grid;
		grid-template-columns: 6.5rem 1fr;
		gap: var(--space-md);
		padding-block: var(--space-lg);
		border-bottom: 1px solid var(--color-border);
		text-decoration: none;
		color: inherit;
		transition: background var(--transition-base);
	}

	.post-link:hover {
		background: var(--color-surface);
	}

	.post-date {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--color-text-faint);
		padding-top: 0.35em;
		letter-spacing: 0.02em;
	}

	.date-short {
		display: none;
	}

	.post-body {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		min-width: 0;
	}

	.post-title {
		font-family: var(--font-heading);
		font-size: var(--text-lg);
		font-weight: 700;
		line-height: 1.25;
		display: flex;
		align-items: center;
		gap: var(--space-sm);
		flex-wrap: wrap;
	}

	.post-description {
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		line-height: 1.5;
	}

	.post-facets {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--color-text-faint);
		margin-top: var(--space-xs);
		display: flex;
		flex-direction: column;
		gap: 0.25em;
		grid-column: 2;
	}

	.post-taxonomy {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: var(--space-sm);
	}

	.post-category {
		color: var(--color-text-muted);
	}

	.post-taxonomy .post-category:not(:last-child)::after {
		content: ":";
		color: var(--color-text-faint);
		margin-left: 0.05em;
	}

	.post-tags {
		display: inline-flex;
		flex-wrap: wrap;
		gap: var(--space-sm);
	}

	.post-tag::before {
		content: "#";
		color: var(--color-accent);
		opacity: 0.75;
		margin-right: 0.1em;
	}

	.draft-badge {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		font-weight: 500;
		color: var(--color-accent);
		border: 1px solid var(--color-accent);
		border-radius: 3px;
		padding: 0.05em 0.4em;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.post-item.draft .post-title {
		color: var(--color-text-muted);
	}

	/* --- Index (dense) view --- */

	.year-groups[data-density="index"] .post-link {
		grid-template-columns: 4.5rem minmax(0, 1fr) auto;
		padding-block: var(--space-sm);
		align-items: baseline;
	}

	.year-groups[data-density="index"] .post-date {
		padding-top: 0;
		font-size: var(--text-xs);
	}

	.year-groups[data-density="index"] .date-full {
		display: none;
	}

	.year-groups[data-density="index"] .date-short {
		display: inline;
	}

	.year-groups[data-density="index"] .post-body {
		flex-direction: row;
		align-items: baseline;
		gap: var(--space-sm);
	}

	.year-groups[data-density="index"] .post-title {
		font-family: var(--font-body);
		font-size: var(--text-base);
		font-weight: 500;
		line-height: 1.4;
	}

	.year-groups[data-density="index"] .post-description {
		display: none;
	}

	.year-groups[data-density="index"] .post-facets {
		grid-column: auto;
		margin-top: 0;
		padding-top: 0.2em;
		flex-direction: row;
		justify-content: flex-end;
		gap: var(--space-sm);
	}

	.year-groups[data-density="index"] .post-tags {
		display: none;
	}


	/* --- Filter rail --- */

	.filter-rail {
		margin-top: var(--space-2xl);
		display: flex;
		flex-direction: column;
		gap: var(--space-xl);
	}

	@media (min-width: 72rem) {
		.filter-rail {
			position: sticky;
			top: calc(var(--header-height, 4rem) + var(--space-lg));
			margin-top: calc(var(--space-3xl) + 0.3em);
			max-height: calc(100vh - var(--header-height, 4rem) - var(--space-xl));
			overflow-y: auto;
			padding-right: var(--space-sm);
		}
	}

	.rail-section {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
	}

	.rail-label {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		font-weight: 600;
		color: var(--color-accent);
		text-transform: uppercase;
		letter-spacing: 0.12em;
	}

	.rail-list {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}

	.rail-list a {
		font-family: var(--font-body);
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		padding-block: 0.1em;
		cursor: pointer;
		transition: color var(--transition-base);
	}

	.rail-list a:hover {
		color: var(--color-accent);
	}

	.rail-list a.active {
		color: var(--color-accent);
		font-weight: 600;
		border-bottom: 1px solid var(--color-accent);
		align-self: flex-start;
	}

	.rail-years {
		font-family: var(--font-mono);
		flex-direction: row;
		flex-wrap: wrap;
		gap: var(--space-sm);
	}

	.rail-years a {
		font-family: var(--font-mono);
	}

	.rail-tags {
		flex-direction: row;
		flex-wrap: wrap;
		gap: var(--space-xs) var(--space-sm);
	}

	.rail-tags a::before {
		content: "#";
		color: var(--color-accent);
		opacity: 0.7;
		margin-right: 0.05em;
	}

	.density-toggle {
		display: flex;
		align-items: center;
		gap: var(--space-xs);
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--color-text-faint);
	}

	.density-toggle button {
		background: none;
		border: none;
		padding: 0;
		font: inherit;
		color: inherit;
		cursor: pointer;
		transition: color var(--transition-base);
	}

	.density-toggle button:hover {
		color: var(--color-accent);
	}

	.density-toggle button.active {
		color: var(--color-text);
		border-bottom: 1px solid var(--color-accent);
	}

	.no-results {
		font-style: italic;
		color: var(--color-text-muted);
		padding-block: var(--space-xl);
	}

	/* --- Narrow viewport: dense post cards, inline rail --- */

	@media (max-width: 71.99rem) {
		.post-link {
			grid-template-columns: 5rem 1fr;
			gap: var(--space-sm);
		}

		.date-full {
			display: none;
		}

		.date-short {
			display: inline;
